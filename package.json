{
  "name": "typing-language-learning",
  "private": true,
  "version": "0.13.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "validate": "node scripts/validate-sentences.mjs",
    "add-words": "node scripts/add-words.mjs",
    "gen-sentences": "node scripts/gen-sentences.mjs",
    "merge-sentences": "node scripts/merge-sentences.mjs",
    "gen-dict": "node scripts/gen-dict.mjs",
    "merge-dict": "node scripts/merge-dict.mjs",
    "check-readings": "node scripts/check-readings.mjs",
    "check": "npm run lint && npm run test && npm run validate && npm run build && npm run check-bundle",
    "check:ci": "bash scripts/check-ci.sh",
    "check-bundle": "node scripts/check-bundle.mjs",
    "audit": "npm audit --omit=dev --audit-level=high",
    "screenshots": "node scripts/screenshots.mjs",
    "electron": "electron .",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:127.0.0.1:5173 && electron .\"",
    "dist": "vite build && electron-builder",
    "dist:dir": "vite build && electron-builder --dir"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.example.typinggame",
    "productName": "EigoTyping",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.education"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Education"
    }
  }
}
